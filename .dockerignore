# Development and build tools
Makefile
docker-compose*.yml
Dockerfile*
.dockerignore
nginx.conf

# Logs and temporary files
logs/
*.log
tmp/
temp/
.tmp/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
