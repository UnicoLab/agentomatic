# ==============================================================================
# Agentomatic — Environment Configuration
# ==============================================================================
# Copy to .env and customize as needed.

# --- Application ---
APP_NAME="My Agent Platform"
APP_ENV=development
LOG_LEVEL=INFO

# --- LLM Configuration ---
LLM__PROVIDER=ollama
LLM__MODEL=mistral:7b
LLM__TEMPERATURE=0.1
LLM__MAX_TOKENS=4096
LLM__OLLAMA_BASE_URL=http://localhost:11434

# Azure OpenAI (if LLM__PROVIDER=azure)
# LLM__AZURE_API_KEY=sk-...
# LLM__AZURE_API_BASE=https://your-endpoint.openai.azure.com/
# LLM__AZURE_API_VERSION=2024-02-15-preview
# LLM__AZURE_DEPLOYMENT_NAME=gpt-4

# OpenAI (if LLM__PROVIDER=openai)
# LLM__OPENAI_API_KEY=sk-...

# Google Vertex AI (if LLM__PROVIDER=vertex)
# LLM__VERTEX_PROJECT=my-project
# LLM__VERTEX_LOCATION=us-central1

# --- Embedding ---
EMBEDDING__PROVIDER=dummy
EMBEDDING__MODEL=nomic-embed-text
EMBEDDING__DIMENSION=768

# --- Database ---
DB__URL=sqlite+aiosqlite:///data/platform.db
# DB__URL=postgresql+asyncpg://user:pass@localhost:5432/agentomatic
DB__POOL_SIZE=10
DB__MAX_OVERFLOW=20

# --- Feature Flags ---
FEATURES__ENABLE_STREAMING=true
FEATURES__ENABLE_A2A=true
FEATURES__ENABLE_METRICS=true
FEATURES__ENABLE_RATE_LIMIT=false
FEATURES__ENABLE_AUTH=false
FEATURES__ENABLE_DB=false
FEATURES__ENABLE_FEEDBACK=true
FEATURES__MAX_CONCURRENT_AGENTS=10
FEATURES__REQUEST_TIMEOUT=30.0
FEATURES__LLM_RETRY_COUNT=3
FEATURES__LLM_RETRY_DELAY=1.0
FEATURES__CIRCUIT_BREAKER_THRESHOLD=5
FEATURES__CIRCUIT_BREAKER_TIMEOUT=60.0

# --- Authentication ---
# AUTH__API_KEY=your-secret-api-key

# --- Rate Limiting ---
RATE_LIMIT__REQUESTS=100
RATE_LIMIT__WINDOW_SECONDS=60
